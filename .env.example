# ============================================================
# PPE Detection — Docker environment
# Copy this file to `.env`, adjust as needed, then:
#     docker compose up --build
# ============================================================

# ---- Host ports (avoid 8000 to prevent conflicts) ----
# Web UI (nginx) — the only port exposed to the host by default.
WEB_PORT=8088
# Backend host port — only used if you uncomment `ports:` on the backend
# service in docker-compose.yml. Internal container port stays 8000.
BACKEND_PORT=9000

# ============================================================
# DATABASE
# ============================================================
# A bundled MySQL 8 container is used by default (see `db` service in
# docker-compose.yml). Its port 3306 is NOT published to the host, so it
# will NOT conflict with any MySQL already on the server.
#
# >>> To use an EXTERNAL MySQL (the school server's own, for example):
#     1. Comment out the entire `db` service in docker-compose.yml
#        AND the `depends_on` block on the `backend` service.
#     2. Set DB_HOST / DB_PORT / DB_USER / DB_PASSWORD / DB_NAME below.
#     3. Import backend/schema.sql into that MySQL once (creates the
#        `ppe_detection` DB, tables, and default admin user admin/admin123).
# ============================================================

# Read by the backend at runtime (see backend/database.py):
DB_HOST=db
DB_PORT=3306
DB_USER=root
# For the bundled MySQL below you can leave this commented — docker-compose.yml
# defaults DB_PASSWORD to MYSQL_ROOT_PASSWORD automatically. Only set it when
# pointing at an EXTERNAL MySQL with its own password.
# DB_PASSWORD=changeme
DB_NAME=ppe_detection

# Used by the bundled `db` service. Change this to secure the database.
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=ppe_detection

# ============================================================
# SMTP Email (password reset / OTP) — optional, leave as-is to disable
# Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-app@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=Deteksi APD
SMTP_FROM_EMAIL=your-app@gmail.com
